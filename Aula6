Select    Paciente.nome, Consulta.data, Medico.nome 
From      Paciente, Medico, Consulta
Where     Medico.especialidade == "Traumato" and Medico.id_Medico == Consulta.id_Medico and Paciente.id_Paciente == Conulta.id=Paciente; 

